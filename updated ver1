      width: double.infinity,
      padding: const EdgeInsets.only(left: 10),
      decoration: BoxDecoration(
        color: Theme.of(context).scaffoldBackgroundColor.withOpacity(0.1), // 입력 필드 배경색
        borderRadius: BorderRadius.circular(8),
      ),
