class _Taipei101Painter extends CustomPainter {
  @override
  void paint(Canvas canvas, Size size) {
    final paint = Paint()
      ..color = Colors.white
      ..style = PaintingStyle.stroke
      ..strokeWidth = size.width * 0.025
      ..strokeCap = StrokeCap.round;

    final path = Path();
    final double w = size.width;
    final double h = size.height;

    double currentH = h * 0.4;
    double segmentW = w * 0.4;
    for (int i = 0; i < 8; i++) {
      path.moveTo(w * 0.5 - segmentW / 2, currentH);
      path.lineTo(w * 0.5 - segmentW * 0.4 / 2, currentH - h * 0.04);
      path.lineTo(w * 0.5 + segmentW * 0.4 / 2, currentH - h * 0.04);
      path.lineTo(w * 0.5 + segmentW / 2, currentH);
      currentH -= h * 0.04;
      segmentW *= 0.92;
    }
    path.moveTo(w * 0.5, currentH);
    path.lineTo(w * 0.5, h * 0.05);

    // 하단 무한대(∞) 심볼
    final double infoCenterY = h * 0.6;
    final double infoRadius = w * 0.25;
    path.addOval(Rect.fromCircle(center: Offset(w * 0.35, infoCenterY), radius: infoRadius * 0.8));
    path.addOval(Rect.fromCircle(center: Offset(w * 0.65, infoCenterY), radius: infoRadius * 0.8));
    path.moveTo(w * 0.5, h * 0.4);
    path.lineTo(w * 0.5, h * 0.8);

    canvas.drawPath(path, paint);
  }

  @override
  bool shouldRepaint(covariant CustomPainter oldDelegate) => false;
}
