class CryptoOrderPanel extends StatefulWidget {
  final double currentPrice; // 현재 코인 가격

  const CryptoOrderPanel({super.key, required this.currentPrice});

  @override
  State<CryptoOrderPanel> createState() => _CryptoOrderPanelState();
}

class _CryptoOrderPanelState extends State<CryptoOrderPanel> with SingleTickerProviderStateMixin {
  late TabController _tabController;
  final TextEditingController _quantityController = TextEditingController(); // 수량 입력 필드 컨트롤러
  final TextEditingController _priceController = TextEditingController(); // 가격 입력 필드 컨트롤러
  bool _isChartVisible = false;

  // 상태 변수들
  double _totalAmount = 0.0; // 총액
  double _krwBalance = 100000000.0; // 사용자의 가상 원화 잔고 (1억 KRW)
  double _btcBalance = 0.5; // 사용자의 가상 비트코인 잔고 (0.5 BTC)
  double _selectedPrice = 0.0; // 사용자가 선택한 호가 가격

  // 가상의 호가 데이터 (이미지와 비슷하게 구성)
  final List<Map<String, dynamic>> _askHogas = []; // 매도 호가 (파란색 계열)
  final List<Map<String, dynamic>> _bidHogas = []; // 매수 호가 (빨간색 계열)

  @override
  void initState() {
    super.initState();
    // 탭바 컨트롤러 초기화 (0: 매수, 1: 매도, 2: 거래내역)
    _tabController = TabController(length: 3, vsync: this);
    _selectedPrice = widget.currentPrice;
    _priceController.text = _formatNumber(widget.currentPrice); // 초기 가격 설정
    _quantityController.text = '0.0';
    _updateTotal(); // 초기 총액 계산

    // 가상의 호가 데이터 생성
    _generateDummyHogas();
  }

  @override
  void dispose() {
    _tabController.dispose();
    _quantityController.dispose();
    _priceController.dispose();
    super.dispose();
  }

  // 총액 업데이트 함수
  void _updateTotal() {
    setState(() {
      final double quantity = double.tryParse(_quantityController.text.replaceAll(',', '')) ?? 0.0;
      final double price = double.tryParse(_priceController.text.replaceAll(',', '')) ?? 0.0;
      _totalAmount = quantity * price;
    });
  }

  // 숫자 포맷 함수 (세자리마다 콤마)
  String _formatNumber(double number) {
    return number.toStringAsFixed(0).replaceAllMapped(RegExp(r'(\d{1,3})(?=(\d{3})+(?!\d))'), (Match m) => '${m[1]},');
  }

  // 가상의 호가 데이터 생성 함수 (현재가 기준으로 위아래 생성)
  void _generateDummyHogas() {
    // 매도 호가 (위로 갈수록 비싸짐)
    for (int i = 5; i > 0; i--) {
      _askHogas.add({
        'price': widget.currentPrice + (i * 10000.0), // 가격 단위 1만 원으로 설정
        'change': -5.00 + (0.01 * i), // 가상의 전일대비
        'quantity': 0.001 + (0.1 * i), // 가상의 수량
      });
    }
    // 매수 호가 (아래로 갈수록 싸짐)
    for (int i = 1; i <= 5; i++) {
      _bidHogas.add({
        'price': widget.currentPrice - (i * 10000.0), // 가격 단위 1만 원으로 설정
        'change': -5.01 - (0.1 * i), // 가상의 전일대비
        'quantity': 1.555 - (0.1 * i), // 가상의 수량
      });
    }
  }

  // 주문 실행 시뮬레이션 함수
  void _executeOrder(String orderType) {
    final double quantity = double.tryParse(_quantityController.text.replaceAll(',', '')) ?? 0.0;
    final double price = double.tryParse(_priceController.text.replaceAll(',', '')) ?? 0.0;
    final double total = quantity * price;

    if (quantity <= 0 || price <= 0) {
      ScaffoldMessenger.of(context).showSnackBar(const SnackBar(content: Text("請輸入有效的數量和價格。"), backgroundColor: Colors.orange));
      return;
    }

    if (orderType == '매수') {
      if (total > _krwBalance) {
        ScaffoldMessenger.of(context).showSnackBar(const SnackBar(content: Text("餘額 KRW 不足。"), backgroundColor: Colors.red));
      } else {
        setState(() {
          _krwBalance -= total;
          _btcBalance += quantity;
          ScaffoldMessenger.of(context).showSnackBar(SnackBar(content: Text("已下單 NT\$ ${_formatNumber(total)} 買入。"), backgroundColor: Colors.green));
          // 입력 필드 초기화
          _quantityController.text = '0.0';
          _updateTotal();
        });
      }
    } else if (orderType == '매도') {
      if (quantity > _btcBalance) {
        ScaffoldMessenger.of(context).showSnackBar(const SnackBar(content: Text("餘額 BTC 不足。"), backgroundColor: Colors.red));
      } else {
        setState(() {
          _btcBalance -= quantity;
          _krwBalance += total;
          ScaffoldMessenger.of(context).showSnackBar(SnackBar(content: Text("已下單 NT\$ ${_formatNumber(total)} 賣出。"), backgroundColor: Colors.green));
          // 입력 필드 초기화
          _quantityController.text = '0.0';
          _updateTotal();
        });
      }
    }
  }

  @override
  Widget build(BuildContext context) {
    final bool isDarkMode = Theme.of(context).brightness == Brightness.dark;

    return Row(
      children: [
        // --- 1. 왼쪽: 호가창 영역 (보여주신 사진의 왼쪽 부분) ---
        Expanded(
          flex: 2, // 호가창이 주문창보다 좁게
          child: Container(
            color: isDarkMode ? Colors.black.withOpacity(0.5) : const Color(0xFFE8F1FC), // 매도 루프 배경색
            child: ListView(
              padding: const EdgeInsets.only(top: 10),
              children: [
                // 1-1. 매도 호가 리스트 (파란색 계열)
                ..._askHogas.map((hoga) => _buildHogaRow(hoga, Colors.blue[900]!, Colors.blue[100]!)),

                // 1-2. 현재가 행 (강조 표시)
                _buildCurrentPriceRow(),

                // 1-3. 매수 호가 리스트 (빨간색 계열)
                ..._bidHogas.map((hoga) => _buildHogaRow(hoga, Colors.red[900]!, Colors.red[100]!)),

                const SizedBox(height: 20),
                // 하단 수량(BTC) 버튼
                Center(
                  child: TextButton(
                      onPressed: () {},
                      child: Text("數量(BTC) ▲", style: TextStyle(color: isDarkMode ? Colors.white70 : Colors.black87),)),
                ),
                const SizedBox(height: 10),
              ],
            ),
          ),
        ),

        // --- 2. 오른쪽: 주문창 영역 (보여주신 사진의 오른쪽 부분) ---
        Expanded(
          flex: 3, // 주문창이 호가창보다 넓게
          child: Column(
            children: [
              Align(
                alignment: Alignment.topRight,
                child: InkWell(
                  onTap: () {
                    setState(() {
                      _isChartVisible = !_isChartVisible; // 클릭 시 차트 토글
                    });
                  },
                  child: Container(
                    padding: const EdgeInsets.all(8),
                    child: Column(
                      crossAxisAlignment: CrossAxisAlignment.end,
                      children: [
                        const Icon(Icons.show_chart, color: Colors.red, size: 20), // 작은 그래프 아이콘
                        Text(_isChartVisible ? "차트 닫기 ▲" : "차트 보기 ▼",
                            style: const TextStyle(fontSize: 10, color: Colors.grey)),
                      ],
                    ),
                  ),
                ),
              ),

              // 2) 조건부 차트 표시 (클릭했을 때만 나타남)
              if (_isChartVisible)
                Container(
                  height: 150, // 펼쳐졌을 때 차트 높이
