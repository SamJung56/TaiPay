// 공통 서브 상세 페이지
class SubDetailPage extends StatefulWidget {
  final String title;
  const SubDetailPage({super.key, required this.title});

  @override
  State<SubDetailPage> createState() => _SubDetailPageState();
}

class _SubDetailPageState extends State<SubDetailPage> {
  // [보내주신 변수들 그대로 유지]
  String _displayPrice = "正在讀取數據... (데이터 읽는 중)";
  bool _isLoading = true;

  // 🚀 [수정] 전역에 있던 myAssets를 클래스 내부로 이동
  List<AssetData> myAssets = [];
  List<FlSpot> _chartData = [];
  double _timeCounter = 0;
  Timer? _timer;
  List<FlSpot> _coinChartData = [];

  @override
  void initState() {
    super.initState();
    _fetchRealTimePrice(); // 기존 호출
    loadData();            // 보내주신 loadData 호출

    _timer = Timer.periodic(const Duration(seconds: 5), (timer) {
      loadData();
      _fetchRealTimePrice();
      print("새로고침 완료: ${DateTime.now()}");
    });
  }

  // 🚀 [중요] 페이지 나갈 때 타이머를 꺼줘야 앱이 안 무거워짐
  @override
  void dispose() {
    _timer?.cancel();
    super.dispose();
  }

  // [수정] 전역에 있던 loadData를 클래스 내부로 이동 (setState 사용 가능해짐)
  void loadData() async {
    try {
      void loadData() async {
        try {
          AssetData stock = await ApiService.fetchTaiwanStock("2330");
          AssetData coin = await ApiService.fetchCoinData("bitcoin");

          if (mounted) {
            setState(() {
              myAssets = [stock, coin];
              // 그래프 점 추가 (가격이 같아도 x축을 늘려 선이 그려지게 함)
              _chartData.add(FlSpot(_timeCounter, stock.price));
              _coinChartData.add(FlSpot(_timeCounter, coin.price));
              _timeCounter += 1;
              if (_chartData.length > 30) _chartData.removeAt(0);
              if (_coinChartData.length > 30) _coinChartData.removeAt(0);
            });
          }
        } catch (e) {
          print("API Error: $e");
        }
      }
      // 대만 주식(2330 - TSMC)과 비트코인 호출
      AssetData stock = await ApiService.fetchTaiwanStock("2330");
      AssetData coin = await ApiService.fetchCoinData("bitcoin");

      setState(() {
        myAssets = [stock, coin];
      });
    } catch (e) {
      print("API Error: $e");
    }
  }

  //  기존 실시간 시세 함수 그대로 유지
  Future<void> _fetchRealTimePrice() async {
    try {
      if (widget.title == "我的付款方式") {
        final response = await http.get(Uri.parse(
            'https://api.coingecko.com/api/v3/simple/price?ids=bitcoin&vs_currencies=twd'));

        if (response.statusCode == 200) {
          final data = jsonDecode(response.body);
          setState(() {
            _displayPrice = "BTC: \$ ${data['bitcoin']['twd']} TWD";
            _isLoading = false;
          });
        }
      } else {
        setState(() {
          _displayPrice = "${widget.title} 畫面準備中";
          _isLoading = false;
        });
      }
    } catch (e) {
      setState(() {
        _displayPrice = "連線 실패 (에러 발생)";
        _isLoading = false;
      });
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: Text(widget.title), elevation: 0),
      body: Center(
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            _isLoading
                ? const CircularProgressIndicator(color: Color(0xFF3182F6))
                : const Icon(Icons.construction_rounded, size: 80, color: Color(0xFFB0B8C1)),
            const SizedBox(height: 20),
            if (_chartData.isNotEmpty)
              Container(
                height: 200,
                padding: const EdgeInsets.symmetric(horizontal: 24),
                child: LineChart(
                  LineChartData(
                    minY: myAssets.isNotEmpty ? (myAssets[0].price - 5) : 0,
                    maxY: myAssets.isNotEmpty ? (myAssets[0].price + 5) : 1000,

                    gridData: FlGridData(show: false),
                    titlesData: FlTitlesData(show: false),
                    borderData: FlBorderData(show: false),
                    lineBarsData: [
                      LineChartBarData(
                        spots: _chartData,
                        isCurved: true,
                        color: const Color(0xFF3182F6), // 0.66.0 버전용 colors 리스트
                        barWidth: 4,
                        dotData: FlDotData(show: false),
                        belowBarData: BarAreaData(
                          show: true,
                          color: const Color(0xFF3182F6).withOpacity(0.1),
                        ),
                      ),
                    ],
                  ),
                ),
              ),
            Padding(
              padding: const EdgeInsets.symmetric(horizontal: 20),
              child: Text(
                  _displayPrice,
                  textAlign: TextAlign.center,
                  style: const TextStyle(
                      fontSize: 20,
                      color: Color(0xFF3182F6),
                      fontWeight: FontWeight.bold
                  )
              ),
            ),
            // loadData로 가져온 데이터가 있을 경우 간단히 표시 (누락 방지)
            if (myAssets.isNotEmpty)
              Text("최신 자산: ${myAssets[0].name} ${myAssets[0].price} TWD"),
          ],
        ),
      ),
    );
  }
} // <--- _SubDetailPageState 클래스 끝

// [10] API 관련 부분 (보내주신 내용 그대로 - 수정 없음)
class AssetData {
  final String name;
  final String symbol;
  final double price;
  final double change;

  AssetData({
    required this.name,
    required this.symbol,
    required this.price,
    required this.change,
  });
}

class ApiService {
  static Future<AssetData> fetchTaiwanStock(String stockId) async {
    // 1. 오늘 기준 7일 전 날짜를 계산 (주말/공휴일 방어용)
    DateTime now = DateTime.now();
    String startDate = "${now.year}-${now.month.toString().padLeft(2, '0')}-${(now.day - 7).toString().padLeft(2, '0')}";

// 2. 고정된 날짜 대신 변수(startDate)를 주소에 넣음
    final url = Uri.parse('https://api.finmindtrade.com/api/v4/data?dataset=TaiwanStockPrice&data_id=$stockId&start_date=$startDate');
    final response = await http.get(url);

    if (response.statusCode == 200) {
      final data = jsonDecode(response.body)['data'].last;
      return AssetData(
        name: "台積電",
        symbol: stockId,
         price: data['close'].toDouble(),
        change: 1.5,
      );
    } else {
      throw Exception('Failed to load Stock');
    }
  }

  static Future<AssetData> fetchCoinData(String coinId) async {
    final url = Uri.parse('https://api.coingecko.com/api/v3/simple/price?ids=$coinId&vs_currencies=twd&include_24hr_change=true');
    final response = await http.get(url);

    if (response.statusCode == 200) {
      final data = jsonDecode(response.body)[coinId];
      return AssetData(
        name: coinId.toUpperCase(),
        symbol: coinId.substring(0, 3).toUpperCase(),
        price: data['twd'].toDouble(),
        change: data['twd_24h_change'].toDouble(),
      );
    } else {
      throw Exception('Failed to load Coin');
    }
  }
}
