        children: [
          // 1) 라벨 (수량/가격)
          SizedBox(width: 35, child: Text(label, style: const TextStyle(color: Colors.grey))),

          // 2) 입력 필드
          Expanded(
            child: TextField(
              controller: controller,
              textAlign: TextAlign.right,
              keyboardType: const TextInputType.numberWithOptions(decimal: true),
              style: const TextStyle(fontSize: 16, fontWeight: FontWeight.bold),
              decoration: const InputDecoration(border: InputBorder.none, contentPadding: EdgeInsets.zero, hintText: '0'),
              onChanged: (value) {
                // 수동 입력 시 포맷팅 및 총액 업데이트
                if (value.isEmpty) {
                  controller.text = '0.0';
                  _updateTotal();
                  return;
                }
                final String unformatted = value.replaceAll(',', '');
                final double num = double.tryParse(unformatted) ?? 0.0;

                // 수량 필드만 소수점 유지, 가격 필드는 정수 포맷
                controller.text = isQuantity ? num.toString() : _formatNumber(num);
                _updateTotal();
              },
            ),
          ),

          // 3) 단위 (BTC/KRW)
          Padding(
            padding: const EdgeInsets.symmetric(horizontal: 10),
            child: Text(suffix, style: const TextStyle(color: Colors.grey)),
          ),

          // 4) 액션 버튼 영역 (+/- 또는 가능▼)
          SizedBox(width: isQuantity ? 70 : 100, child: action),
        ],
      ),
    );
  }
}

// [해결] 클릭 시 나타날 차트 위젯 본체입니다. 파일 맨 밑에 추가하세요.
class CryptoChart extends StatefulWidget {
  final bool isPositive;
  final double basePrice;

  const CryptoChart({super.key, required this.isPositive, required this.basePrice});

  @override
  State<CryptoChart> createState() => _CryptoChartState();
}

class _CryptoChartState extends State<CryptoChart> {
  List<FlSpot> _spots = [];

  @override
  void initState() {
    super.initState();
    _generateData();
  }

  void _generateData() {
    final random = Random();
    _spots = List.generate(15, (i) {
      double fluctuation = (random.nextDouble() - 0.6) * 0.02;
      return FlSpot(i.toDouble(), widget.basePrice * (1 + fluctuation));
    });
  }

  @override
  Widget build(BuildContext context) {
    final chartColor = widget.isPositive ? Colors.red : Colors.blue;

    return LineChart(
      LineChartData(
        gridData: FlGridData(show: false), // const 제거됨
        titlesData: FlTitlesData(show: false), // const 제거됨
        borderData: FlBorderData(show: false),
        lineBarsData: [
          LineChartBarData(
            spots: _spots,
            isCurved: true,
            color: chartColor,
            barWidth: 2,
            dotData: FlDotData(show: false), // const 제거됨
            belowBarData: BarAreaData(
              show: true,
              color: chartColor.withOpacity(0.1),
            ),
          ),
        ],
      ),
    );
  }
}

